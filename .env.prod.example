DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=<generate-a-strong-secret-key>

DOMAIN_NAME=erp.example.com

POSTGRES_DB=bresler_erp
POSTGRES_USER=bresler
POSTGRES_PASSWORD=<strong-password>
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

DJANGO_ALLOWED_HOSTS=erp.example.com
CORS_ALLOWED_ORIGINS=https://erp.example.com

# Email (SMTP)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=erp@example.com
EMAIL_HOST_PASSWORD=<email-password>
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Bresler ERP <erp@example.com>
SITE_URL=https://erp.example.com

# LDAP / Active Directory authentication
# Set AUTH_LDAP_SERVER_URI to enable LDAP. Leave empty to use local auth only.
AUTH_LDAP_SERVER_URI=ldap://dc-srv-a.local.bresler.ru
AUTH_LDAP_BIND_DN=CN=marketing,CN=Users,DC=local,DC=bresler,DC=ru
AUTH_LDAP_BIND_PASSWORD=<ldap-bind-password>
AUTH_LDAP_SEARCH_BASE=DC=local,DC=bresler,DC=ru
AUTH_LDAP_REQUIRE_GROUP=CN=marketing_app_users,OU=Groups,OU=Bresler,DC=local,DC=bresler,DC=ru
AUTH_LDAP_GROUP_SEARCH_BASE=OU=Groups,OU=Bresler,DC=local,DC=bresler,DC=ru
AUTH_LDAP_DEBUG=False

GUNICORN_WORKERS=4
